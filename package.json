  "author": "Zhenye Dong",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
