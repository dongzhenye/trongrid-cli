{
  "name": "trongrid",
  "version": "0.1.0",
  "description": "CLI for TronGrid — query TRON blockchain from terminal or AI agent",
  "type": "module",
  "bin": {
    "trongrid": "dist/index.js"
  },
  "scripts": {
